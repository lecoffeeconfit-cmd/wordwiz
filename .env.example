# These two values are public client configuration. They are bundled into Expo's
# JavaScript and can be viewed by users inspecting the app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# This is RevenueCat's public iOS SDK key (never a RevenueCat secret key).
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your-public-ios-sdk-key

# Never add service-role keys, OpenAI keys, dictionary paid API keys, or other
# private secrets with an EXPO_PUBLIC_ prefix. Put secrets in Supabase Edge
# Functions or another backend instead.
